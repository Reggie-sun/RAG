OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b
EMBEDDING_MODEL_PATH=/home/reggie/bge-m3
EMBEDDING_DEVICE=cuda   
TRANSFORMERS_NO_TRITON=1
HF_SKIP_TORCH_TRITON=1
TORCHINDUCTOR_SKIP=1
export USE_RERANK=true
OLLAMA_TIMEOUT=30
DEBUG_ROUTER=true
OCR_DEVICE=gpu        # 若有 OCR 服务
CPU_WORKERS=1
# MCP_DEBUG=true persistent-terminal-mcp  # 注释掉，避免启动脚本启动MCP服务
WEB_SEARCH_TIMEOUT=20
TAVILY_API_KEY=
WEBSEARCHAPI_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=
WEB_SEARCH_PROVIDERS=
VITE_API_BASE_URL=https://api.srj666.com
VITE_CPU_API_BASE_URL=https://cpu.srj666.com
ENABLE_GPU=true
CUDA_DEVICE=cuda:0 
ENABLE_QUEUE=true
MANAGE_REDIS=true        # 让 start.sh 自动管理 Redis
CELERY_BROKER_URL=redis://localhost:6379/0  #（默认即可）
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Celery 运行选项
CELERY_APP=backend.task.celery_app        # 默认可不写
CELERY_LOGLEVEL=info
CELERY_CONCURRENCY=1

# Feishu / Lark bot integration (optional)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# WeChat Official Account (optional)
WECHAT_TOKEN=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_ENCODING_AES_KEY=

# WeCom / 企业微信 (optional)
WECOM_TOKEN=
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_CORP_SECRET=
WECOM_ENCODING_AES_KEY=

# Customer service integration API key
CUSTOMER_SERVICE_API_KEY=
# Optional rate limit (requests per minute) for customer service API
CUSTOMER_SERVICE_RATE_LIMIT_PER_MINUTE=60
