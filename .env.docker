# Runtime endpoints
OPENAI_API_KEY=sk-your-key
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:14b
OLLAMA_TIMEOUT=30

# Feature flags
ENABLE_GPU=true
CUDA_DEVICE=cuda:0
ENABLE_QUEUE=true
USE_RERANK=true

# Embeddings / models
EMBEDDING_MODEL_PATH=/app/models/bge-m3
EMBEDDING_DEVICE=cuda

# Web search providers (optional)
TAVILY_API_KEY=
WEBSEARCHAPI_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=
WEB_SEARCH_PROVIDERS=tavily,websearchapi,exa,firecrawl

# Frontend defaults
VITE_API_BASE_URL=http://localhost:8000
VITE_CPU_API_BASE_URL=http://localhost:8001

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_LOGLEVEL=info
CELERY_CONCURRENCY=2

# Misc
INTENT_LLM_TIMEOUT=4.5
RETRIEVAL_TOP_K=6

# Reverse proxy / tunneling
RAG_DOMAIN=www.srj666.com
CADDY_ACME_EMAIL=
CLOUDFLARED_TUNNEL_ID=
CLOUDFLARED_UPSTREAM_URL=https://caddy:443
CLOUDFLARED_PROTOCOL=quic
CLOUDFLARED_NO_AUTOUPDATE=true
RAG_GPU_UPSTREAM=rag-api:8000
RAG_CPU_UPSTREAM=cpu-api:8001

# Feishu / Lark bot integration (optional)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# WeChat Official Account (optional)
WECHAT_TOKEN=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_ENCODING_AES_KEY=

# WeCom / 企业微信 (optional)
WECOM_TOKEN=
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_CORP_SECRET=
WECOM_ENCODING_AES_KEY=
